SECRET_KEY=your-secret-key-here
TOKEN_EXPIRE_HOURS=8
GATE_COMMAND_EXPIRE_MINUTES=2

# Roboflow מזהה לוחיות רישוי (מקומי)
# קרא API Key ב: https://app.roboflow.com/ תחת Account Settings
ROBOFLOW_API_KEY=your-roboflow-api-key-here
# מזהה Roboflow Universe: workspace/model-id/version  (דוגמא מוכנית)
ROBOFLOW_MODEL_ID=license-plate-recognition-rxg4e/4

# Minimum OCR confidence to accept a plate (0.0 - 1.0)
MIN_PLATE_CONFIDENCE=0.35

# JWT – שנה את המחרוזת הזו לסוד חזק בסביבת ייצור!
SECRET_KEY=change-this-to-a-strong-random-secret-key-in-production

# תוקף טוקן JWT בשעות
TOKEN_EXPIRE_HOURS=8

# פג תוקף בקשת פתיחת שער ידנית (דקות)
GATE_COMMAND_EXPIRE_MINUTES=2
